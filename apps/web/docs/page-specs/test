< !DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Corpass — Design System & Specification</title><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;450;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet"><style>

/* ============================================================
   CORPASS DESIGN TOKENS  —  this stylesheet IS the system.
   Every value below is the documented, canonical token.
   ============================================================ */
:root {
    /* — Core neutrals (warm, never pure black/white) — */
    --ink: #1C1B17;
    /* primary text, deep surfaces      */
    --ink-2: #3A3934;
    /* strong secondary text            */
    --slate: #6B6960;
    /* muted text, captions             */
    --slate-2: #97948A;
    /* faint text, placeholders         */
    --line: #E4E0D6;
    /* hairline rules, borders          */
    --line-strong: #D2CDC0;
    /* emphasized dividers              */
    --paper: #F4F2EB;
    /* app + marketing canvas (warm)    */
    --paper-2: #ECE9DF;
    /* recessed wells, table zebra      */
    --surface: #FDFCF8;
    /* cards, panels                    */
    --surface-2: #FFFFFF;
    /* raised/elevated surfaces         */

    /* — Identity: Evergreen (primary / money / trust) — */
    --green-900: #13352A;
    --green-700: #1E4D3A;
    /* primary brand                    */
    --green-600: #2C6B50;
    /* interactive / hover              */
    --green-500: #3C8466;
    --green-100: #DCE8DF;
    /* tints, active-nav wash           */
    --green-050: #EDF3ED;

    /* — Accent: Copper (warmth, secondary energy) — */
    --copper-700: #9A4F22;
    --copper-600: #B5632E;
    /* accent base                      */
    --copper-100: #F1E1D2;

    /* — Semantic status (the procurement state machine) — */
    --info: #2D5C86;
    --info-100: #DCE6F0;
    /* Placed / neutral */
    --ok: #2C6B50;
    --ok-100: #DCE8DF;
    /* Confirmed/In-Stock/Delivered */
    --warn: #9C7211;
    --warn-100: #F2E9CF;
    /* Low / Pending    */
    --danger: #A8392F;
    --danger-100: #F2DAD6;
    /* Rejected/Out/Dispute */
    --ship: #6B4F9A;
    --ship-100: #E5DEF1;
    /* Shipped (in-transit) */

    /* — Type — */
    --display: 'Fraunces', Georgia, 'Times New Roman', serif;
    --ui: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mono: 'IBM Plex Mono', 'SF Mono', Menlo, monospace;

    /* — Spacing scale (4pt base) — */
    --s1: 4px;
    --s2: 8px;
    --s3: 12px;
    --s4: 16px;
    --s5: 24px;
    --s6: 32px;
    --s7: 48px;
    --s8: 64px;
    --s9: 96px;

    /* — Radius — */
    --r-sm: 6px;
    --r: 10px;
    --r-lg: 16px;
    --r-xl: 22px;
    --r-pill: 999px;

    /* — Elevation (warm-tinted, never blue-gray) — */
    --e1: 0 1px 2px rgba(28, 27, 23, .05), 0 1px 1px rgba(28, 27, 23, .04);
    --e2: 0 4px 14px -4px rgba(28, 27, 23, .12), 0 2px 4px rgba(28, 27, 23, .05);
    --e3: 0 18px 48px -12px rgba(28, 27, 23, .22), 0 4px 10px rgba(28, 27, 23, .06);
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0
}

html {
    scroll-behavior: smooth
}

@media (prefers-reduced-motion:reduce) {
    html {
        scroll-behavior: auto
    }

    * {
        animation: none !important;
        transition: none !important
    }
}

body {
    font-family: var(--ui);
    color: var(--ink);
    background: var(--paper);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    font-feature-settings: "cv05", "ss01";
}

/* ---------- App frame: sticky nav + content ---------- */
.shell {
    display: grid;
    grid-template-columns: 288px 1fr;
    max-width: 1440px;
    margin: 0 auto;
    min-height: 100vh
}

.nav {
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid var(--line);
    background: var(--surface);
    padding: var(--s6) var(--s5);
}

.nav .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--s6)
}

.nav .mark {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: var(--green-700);
    color: #F4F2EB;
    display: grid;
    place-items: center;
    font-family: var(--display);
    font-weight: 600;
    font-size: 19px;
    box-shadow: var(--e1);
    flex: none;
}

.nav .brand b {
    font-family: var(--display);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -.01em
}

.nav .brand small {
    display: block;
    font-size: 11px;
    color: var(--slate);
    letter-spacing: .04em;
    text-transform: uppercase
}

.nav .eyebrow {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--slate-2);
    margin: var(--s5) 0 var(--s2)
}

.nav a {
    display: block;
    color: var(--ink-2);
    text-decoration: none;
    font-size: 14px;
    padding: 6px 10px;
    border-radius: 7px;
    transition: background .15s, color .15s
}

.nav a .n {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--slate-2);
    margin-right: 8px
}

.nav a:hover {
    background: var(--green-050);
    color: var(--green-700)
}

.nav a:hover .n {
    color: var(--green-600)
}

.content {
    padding: var(--s8) clamp(24px, 5vw, 80px);
    max-width: 1000px
}

/* ---------- Document typography ---------- */
.section {
    padding-top: var(--s8);
    margin-top: var(--s8);
    border-top: 1px solid var(--line);
    scroll-margin-top: 24px
}

.section:first-of-type {
    border-top: 0;
    margin-top: 0;
    padding-top: 0
}

.kicker {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--copper-600);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--s3)
}

.kicker::before {
    content: "";
    width: 26px;
    height: 1.5px;
    background: var(--copper-600);
    display: inline-block
}

h1 {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(40px, 6vw, 68px);
    line-height: 1.02;
    letter-spacing: -.02em;
    margin-bottom: var(--s4)
}

h2 {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.08;
    letter-spacing: -.015em;
    margin-bottom: var(--s4)
}

h3 {
    font-family: var(--display);
    font-weight: 600;
    font-size: 23px;
    letter-spacing: -.01em;
    margin: var(--s6) 0 var(--s3)
}

h4 {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: .005em;
    margin: var(--s5) 0 var(--s2)
}

p {
    margin-bottom: var(--s4);
    color: var(--ink-2);
    max-width: 68ch
}

.lead {
    font-size: 20px;
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 60ch
}

strong {
    font-weight: 600;
    color: var(--ink)
}

em {
    font-style: normal;
    font-family: var(--mono);
    font-size: .88em;
    background: var(--paper-2);
    padding: 1px 6px;
    border-radius: 5px;
    color: var(--green-700)
}

a.inline {
    color: var(--green-600);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px
}

ul.clean {
    list-style: none;
    margin: 0 0 var(--s4)
}

ul.clean li {
    position: relative;
    padding-left: 22px;
    margin-bottom: 8px;
    color: var(--ink-2);
    max-width: 66ch
}

ul.clean li::before {
    content: "";
    position: absolute;
    left: 4px;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--green-600)
}

ul.clean li strong {
    color: var(--ink)
}

/* ---------- Ledger rule (the signature) ---------- */
.ledger-note {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--slate);
    border-left: 2px solid var(--copper-600);
    padding: 6px 0 6px 14px;
    margin: var(--s4) 0;
    background: linear-gradient(90deg, var(--paper-2), transparent)
}

/* ---------- Cards & grids in the doc ---------- */
.bento {
    display: grid;
    gap: var(--s3);
    margin: var(--s5) 0
}

.card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: var(--s5);
    box-shadow: var(--e1)
}

.card h4 {
    margin-top: 0
}

.card p {
    font-size: 14px;
    margin-bottom: 0;
    color: var(--slate)
}

/* ---------- Color swatches ---------- */
.swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--s3);
    margin: var(--s5) 0
}

.sw {
    border: 1px solid var(--line);
    border-radius: var(--r);
    overflow: hidden;
    background: var(--surface)
}

.sw .chip {
    height: 70px;
    display: flex;
    align-items: flex-end;
    padding: 8px
}

.sw .meta {
    padding: 8px 10px
}

.sw .meta b {
    display: block;
    font-size: 12.5px
}

.sw .meta code {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--slate)
}

.sw .role {
    font-size: 11px;
    color: var(--slate);
    display: block;
    margin-top: 2px
}

/* ---------- Type specimen ---------- */
.spec-row {
    display: flex;
    align-items: baseline;
    gap: var(--s5);
    padding: var(--s3) 0;
    border-bottom: 1px solid var(--line)
}

.spec-row .tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--slate);
    width: 120px;
    flex: none
}

.spec-row .demo {
    line-height: 1
}

/* ---------- Component demo surface ---------- */
.demo-stage {
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: var(--s6);
    margin: var(--s4) 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s3);
    align-items: center
}

.demo-stage.col {
    flex-direction: column;
    align-items: stretch
}

/* buttons */
.btn {
    font-family: var(--ui);
    font-weight: 550;
    font-size: 14px;
    border-radius: var(--r-sm);
    padding: 10px 18px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: .15s;
    display: inline-flex;
    align-items: center;
    gap: 8px
}

.btn-primary {
    background: var(--green-700);
    color: #F4F2EB;
    box-shadow: var(--e1)
}

.btn-primary:hover {
    background: var(--green-600)
}

.btn-accent {
    background: var(--copper-600);
    color: #FDFCF8
}

.btn-accent:hover {
    background: var(--copper-700)
}

.btn-outline {
    background: transparent;
    color: var(--green-700);
    border-color: var(--line-strong)
}

.btn-outline:hover {
    border-color: var(--green-600);
    background: var(--green-050)
}

.btn-ghost {
    background: transparent;
    color: var(--ink-2)
}

.btn-ghost:hover {
    background: var(--paper-2)
}

.btn-danger {
    background: transparent;
    color: var(--danger);
    border-color: var(--danger-100)
}

/* badges / status */
.badge {
    font-family: var(--mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: .02em;
    padding: 3px 9px 3px 8px;
    border-radius: var(--r-pill);
    display: inline-flex;
    align-items: center;
    gap: 6px
}

.badge .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%
}

.b-info {
    background: var(--info-100);
    color: var(--info)
}

.b-info .dot {
    background: var(--info)
}

.b-ok {
    background: var(--ok-100);
    color: var(--ok)
}

.b-ok .dot {
    background: var(--ok)
}

.b-warn {
    background: var(--warn-100);
    color: var(--warn)
}

.b-warn .dot {
    background: var(--warn)
}

.b-danger {
    background: var(--danger-100);
    color: var(--danger)
}

.b-danger .dot {
    background: var(--danger)
}

.b-ship {
    background: var(--ship-100);
    color: var(--ship)
}

.b-ship .dot {
    background: var(--ship)
}

/* input */
.field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 220px
}

.field label {
    font-size: 12.5px;
    font-weight: 550;
    color: var(--ink-2)
}

.field input,
.field select {
    font-family: var(--ui);
    font-size: 14px;
    padding: 10px 12px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-sm);
    background: var(--surface-2);
    color: var(--ink)
}

.field input:focus {
    outline: 2px solid var(--green-600);
    outline-offset: 1px;
    border-color: transparent
}

.field .mono-in {
    font-family: var(--mono)
}

/* ASCII wireframe block */
.wire {
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.5;
    background: var(--ink);
    color: #C9C5B6;
    border-radius: var(--r-lg);
    padding: var(--s5);
    overflow-x: auto;
    margin: var(--s4) 0;
    white-space: pre;
    box-shadow: var(--e2)
}

.wire .hl {
    color: var(--green-500)
}

.wire .ac {
    color: var(--copper-600)
}

.wire .dim {
    color: #6E6B5E
}

/* ledger table demo */
.ltab {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
    margin: var(--s4) 0;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden
}

.ltab th {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--slate);
    text-align: left;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line-strong);
    background: var(--paper-2)
}

.ltab td {
    padding: 13px 16px;
    border-bottom: 1px solid var(--line);
    color: var(--ink-2)
}

.ltab tr:last-child td {
    border-bottom: 0
}

.ltab .num {
    font-family: var(--mono);
    text-align: right;
    color: var(--ink)
}

.ltab .id {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--slate)
}

/* callout */
.callout {
    border: 1px solid var(--line);
    border-left: 3px solid var(--green-600);
    background: var(--green-050);
    border-radius: var(--r);
    padding: var(--s4) var(--s5);
    margin: var(--s4) 0
}

.callout.warn {
    border-left-color: var(--copper-600);
    background: var(--copper-100)
}

.callout p {
    margin: 0;
    font-size: 14px;
    color: var(--ink-2)
}

.callout b {
    color: var(--ink)
}

/* page-spec header */
.page-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding-bottom: var(--s3);
    border-bottom: 1.5px solid var(--ink);
    margin-bottom: var(--s4)
}

.page-head .route {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--green-700);
    background: var(--green-050);
    padding: 4px 10px;
    border-radius: var(--r-sm)
}

.two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s5)
}

@media(max-width:880px) {
    .shell {
        grid-template-columns: 1fr
    }

    .nav {
        position: static;
        height: auto;
        border-right: 0;
        border-bottom: 1px solid var(--line)
    }

    .two {
        grid-template-columns: 1fr
    }

    .content {
        padding: var(--s6) var(--s5)
    }
}

footer {
    margin-top: var(--s9);
    padding-top: var(--s6);
    border-top: 1px solid var(--line);
    color: var(--slate);
    font-size: 13px
}

