pageType: chapter
background:
  type: solid
  color: "$background"
elements:
  - elementId: ch5-left-bg
    elementType: shape
    bounds: [0, 0, 640, 720]
    shapeName: rect
    fill:
      type: solid
      color: "$copper"

  - elementId: ch5-num
    elementType: text
    bounds: [60, 260, 520, 100]
    content:
      style: "$chapterNum"
      align: [left, middle]
      wrap: false
      text: |
        <p>05</p>

  - elementId: ch5-title
    elementType: text
    bounds: [700, 280, 520, 50]
    content:
      style: "$chapterTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p>How It Works</p>

  - elementId: ch5-subtitle
    elementType: text
    bounds: [700, 340, 520, 30]
    content:
      style: "$subtitle"
      align: [left, middle]
      wrap: false
      text: |
        <p>The order lifecycle from inquiry to asset</p>

  - elementId: ch5-line
    elementType: shape
    bounds: [700, 390, 60, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "$copper"