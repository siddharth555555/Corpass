  - elementId: s-detail2
    elementType: text
    bounds: [640, 520, 580, 100]
    content:
      fontSize: 16
      color: "$slate"
      fontFamily: "Liter"
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><strong style="color:$ink;">For Sellers:</strong> A new channel for corporate buyers. Verified transactions build reputation. Commission-only pricing.</p>

  - elementId: s-pagenum
    elementType: text
