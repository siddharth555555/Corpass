pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: s-title
    elementType: text
    bounds: [60, 50, 1100, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>Corpass: Procurement + Asset Management in One Flow</p>

  - elementId: s-line
    elementType: shape
    bounds: [60, 105, 80, 0]
    shapeName: straightConnector1
    border:
      style: solid
      width: 2
      color: "$copper"

  - elementId: s-step1-num
    elementType: shape
    bounds: [60, 150, 40, 40]
    shapeName: rect
    fill:
      type: solid
      color: "$copper"

  - elementId: s-step1-num-text
    elementType: text
    bounds: [60, 150, 40, 40]
    content:
      fontSize: 18
      color: "#ffffff"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p>1</p>

  - elementId: s-step1-title
