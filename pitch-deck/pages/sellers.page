pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: se-title
    elementType: text
    bounds: [60, 50, 1100, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p>Sellers: A New Channel for Corporate Revenue</p>

  - elementId: se-line
    elementType: shape
    bounds: [60, 105, 80, 0]
